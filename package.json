{
	"name": "middiefy",
	"type": "module",
	"version": "0.3.0",
	"packageManager": "pnpm@11.1.2",
	"author": "zhong666 <hi@zhong666.me>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/aa900031/middiefy"
	},
	"keywords": [
		"middleware",
		"middify",
		"onion"
	],
	"exports": {
		".": "./src/index.ts",
		"./helper": "./src/helper.ts",
		"./package.json": "./package.json"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.cts",
	"typesVersions": {
		"*": {
			".": [
				"./dist/index.d.mts"
			]
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"bench": "vitest bench --run",
		"release": "release-it",
		"lint": "eslint .",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@aa900031/eslint-config": "^6.1.2",
		"@aa900031/release-it-config": "^0.1.2",
		"@aa900031/tsdown-config": "^0.2.2",
		"@codspeed/vitest-plugin": "^5.7.1",
		"@tsconfig/node22": "^22.0.5",
		"@types/node": "^22.20.0",
		"@vitest/coverage-istanbul": "^3.2.6",
		"eslint": "^9.39.4",
		"release-it": "^19.2.4",
		"tsdown": "^0.22.3",
		"typescript": "~5.9.3",
		"vitest": "^3.2.6"
	},
	"publishConfig": {
		"exports": {
			".": {
				"import": {
					"types": "./dist/index.d.ts",
					"default": "./dist/index.js"
				},
				"require": {
					"types": "./dist/index.d.cts",
					"default": "./dist/index.cjs"
				}
			},
			"./helper": {
				"import": {
					"types": "./dist/helper.d.ts",
					"default": "./dist/helper.js"
				},
				"require": {
					"types": "./dist/helper.d.cts",
					"default": "./dist/helper.cjs"
				}
			},
			"./package.json": "./package.json"
		}
	}
}
